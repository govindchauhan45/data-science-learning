# ==============================
# NUMPY INTRODUCTION (TOPIC 1)
# ==============================

# 1. Install NumPy (run only once in Jupyter)
# !pip install numpy

# 2. Import NumPy
import numpy as np
import time

print("NumPy Imported Successfully\n")

# ==============================
# 3. Python List vs NumPy Array
# ==============================

# Python list
python_list = [1,2,3,4,5]

# NumPy array
numpy_array = np.array([1,2,3,4,5])

print("Python List:", python_list)
print("NumPy Array:", numpy_array)

print("\nType of Python list:", type(python_list))
print("Type of NumPy array:", type(numpy_array))


# ==============================
# 4. Mathematical Operations
# ==============================

print("\nMathematical Operations")

# Python list multiplication
list_result = [x*2 for x in python_list] # Using list comprehension to multiply each element by 2

# NumPy multiplication
numpy_result = numpy_array * 2 # NumPy allows element-wise multiplication directly

print("Python List Result:", list_result)
print("NumPy Array Result:", numpy_result)


# ==============================
# 5. Speed Comparison
# ==============================

print("\nSpeed Comparison")

# Large dataset
size = 1000000

# Python list
list_data = list(range(size)) # Using list comprehension to create a list of numbers from 0 to size-1

start = time.time() # Start time for Python list multiplication
result = [x*2 for x in list_data] # Using list comprehension to multiply each element by 2
end = time.time() # End time for Python list multiplication

print("Python list time:", end-start)

# NumPy array
array_data = np.arange(size)

start = time.time()
result = array_data * 2
end = time.time()

print("NumPy array time:", end-start)


# ==============================
# 6. Basic NumPy Info
# ==============================

print("\nNumPy Information")

print("NumPy version:", np.__version__)
print("Array dimensions:", numpy_array.ndim)
print("Array shape:", numpy_array.shape)
print("Array data type:", numpy_array.dtype)

print("\nNumPy Introduction Complete!")
